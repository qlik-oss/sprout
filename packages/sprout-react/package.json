{
  "name": "@qlik/sprout-react",
  "version": "6.45.2",
  "homepage": "https://github.com/qlik-oss/sprout#readme",
  "bugs": {
    "url": "https://github.com/qlik-oss/sprout/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/qlik-oss/sprout.git",
  "sideEffects": false,
  "module": "./lib/sprout-react.js",
  "types": "./lib/sprout-react.d.ts",
  "exports": {
    ".": {
      "import": "./lib/sprout-react.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "pnpm run build:tsc",
    "build:tsc": "tsc -p tsconfig.npm.json && pnpm run copy",
    "build:watch": "concurrently \"tsc -p tsconfig.npm.json --watch\" \"pnpm run copy:watch\"",
    "check-types": "tsc --noEmit -p tsconfig.npm.json",
    "clean": "rimraf playwright-report storybook-static test-results playwright/.cache lib stylelint-report.json eslint-report.json",
    "code-connect": "figma connect",
    "code-connect:check": "figma connect publish --dry-run",
    "code-connect:publish": "figma connect publish",
    "copy": "cpx -v \"src/**/*.css\" lib && pnpm run copy:i18n",
    "copy:watch": "cpx \"src/**/*.css\" lib --watch",
    "copy:i18n": "node i18n.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:css:fix": "stylelint --fix 'src/**/*.css'",
    "lint:ci": "eslint . -f json -o eslint-report.json && stylelint 'src/**/*.css' -f json -o stylelint-report.json",
    "test:vitest": "vitest run",
    "test:playwright": "playwright test",
    "playwright:test:ui": "playwright test --ui",
    "playwright:install": "pnpm -w exec playwright install --with-deps"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@qlik/design-tokens": "workspace:^",
    "@qlik/sprout-css-modules": "workspace:^",
    "@qlik/sprout-icons": "0.2.2",
    "@qlik/sprout-react-hooks": "workspace:^"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@figma/code-connect": "^1.4.2",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@qlik/browserslist-config": "^3.0.0",
    "@qlik/eslint-config-sprout": "workspace:^",
    "@qlik/stylelint-config-sprout": "workspace:^",
    "@qlik/tsconfig": "^0.3.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "cpx2": "^8.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-vitest": "^0.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "rimraf": "6.1.3",
    "stylelint": "^17.5.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "browserslist": [
    "extends @qlik/browserslist-config"
  ]
}
