{
  "name": "@qlik/sprout-react-table",
  "version": "0.16.6",
  "homepage": "https://github.com/qlik-oss/sprout#readme",
  "bugs": {
    "url": "https://github.com/qlik-oss/sprout/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/qlik-oss/sprout.git",
  "files": [
    "lib",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "pnpm run build:tsc && pnpm run copy",
    "build:tsc": "tsc -p tsconfig.build.json",
    "build:watch": "concurrently \"pnpm run build:tsc --watch\" \"pnpm run copy:watch\"",
    "build-storybook": "storybook build",
    "check-types": "tsc -p tsconfig.build.json --noEmit",
    "clean": "rimraf playwright-report storybook-static test-results playwright/.cache lib",
    "copy": "cpx \"src/**/*.{css,json}*\" lib",
    "copy:watch": "cpx \"src/**/*.{css,json}*\" lib --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . -f json -o eslint-report.json",
    "start": "storybook dev",
    "playwright:install": "playwright install --with-deps",
    "test:playwright": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@qlik/sprout-icons": "0.4.1",
    "@qlik/sprout-react": "workspace:^",
    "@qlik/sprout-react-hooks": "workspace:^",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.4.0",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@qlik/design-tokens": "workspace:^",
    "@qlik/eslint-config-sprout": "workspace:^",
    "@qlik/tsconfig": "^0.3.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "cpx2": "^8.0.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-svelte": "^3.16.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "glob": "^13.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.3",
    "storybook-addon-pseudo-states": "^10.3.3",
    "storybook-addon-rtl": "^3.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
