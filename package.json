{
  "name": "sprout",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:watch": "pnpm run --parallel build:watch",
    "check": "pnpm check-types && pnpm lint && pnpm format:check && pnpm test",
    "check-types": "turbo run check-types",
    "clean": "pnpm clean:build && pnpm clean:cache",
    "clean:build": "pnpm run --parallel clean",
    "clean:cache": "rimraf */*/.turbo .turbo */*/node_modules/.cache node_modules/.cache",
    "code-connect:check": "turbo run code-connect:check",
    "css:start": "pnpm --filter @qlik/sprout-css-modules start",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "lint": "turbo run lint --continue",
    "lint:ci": "turbo run lint:ci --continue",
    "lint-merge-report": "node ./scripts/lint-merge-report.mjs",
    "lint-throw-error": "node ./scripts/lint-throw-error.mjs",
    "playwright:install": "turbo run --concurrency 1 playwright:install",
    "prepare-release": "changeset",
    "publish-packages": "changeset publish",
    "storybook:build": "turbo run storybook:build",
    "storybook:start": "concurrently \"pnpm run build:watch\" \"pnpm --filter @qlik/storybook start\"",
    "test:node": "turbo run test:node",
    "test:playwright": "turbo run test:playwright --concurrency 1",
    "test:vitest": "turbo run test:vitest"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/chroma-js": "^3.1.2",
    "@types/systemjs": "^6.15.4",
    "concurrently": "^9.2.1",
    "glob": "^13.0.6",
    "oxfmt": "^0.41.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.20",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "updateConfig": {
      "ignoreDependencies": [
        "eslint",
        "react",
        "react-dom"
      ]
    }
  }
}
