{
  "name": "@qlik/eslint-config-sprout",
  "version": "1.0.10",
  "homepage": "https://github.com/qlik-oss/sprout#readme",
  "bugs": {
    "url": "https://github.com/qlik-oss/sprout/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/qlik-oss/sprout.git",
  "type": "module",
  "main": "./src/index.mjs",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./react": {
      "types": "./src/react.d.ts",
      "import": "./src/react.mjs"
    },
    "./rules": {
      "types": "./src/rules.d.ts",
      "import": "./src/rules.mjs"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:ci": "eslint . -f json -o eslint-report.json",
    "test:vitest": "vitest run"
  },
  "dependencies": {
    "@qlik/eslint-config": "^1.4.26",
    "@qlik/eslint-plugin-sprout": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "eslint-plugin-react": "^7.37.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "eslint": "^9.35.0"
  }
}
