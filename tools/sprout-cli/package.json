{
  "name": "@qlik/sprout-cli",
  "version": "1.0.2",
  "description": "CLI tools for Qlik Design System Sprout",
  "license": "MIT",
  "bin": {
    "sprout": "./sprout-cli.js"
  },
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@tokens-studio/sd-transforms": "^2.0.3",
    "commander": "^14.0.3",
    "style-dictionary": "^5.4.0"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@qlik/tsconfig": "^0.3.1",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
