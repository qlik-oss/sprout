{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "lib/**", "build/**"]
    },
    "@qlik/sprout-css-modules#build": {
      "outputs": ["src/*.js", "src/*.d.ts", "src/*.js.map", "dist/**"]
    },
    "@qlik/sprout-icons#build": {
      "outputs": ["react/**", "vue/**"]
    },
    "code-connect:check": {
      "env": ["FIGMA_ACCESS_TOKEN"]
    },
    "start": {},
    "storybook:build": {
      "dependsOn": ["^storybook:build"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {},
    "lint:ci": {
      "dependsOn": ["^lint:ci"],
      "outputs": ["**/stylelint-report.json", "**/eslint-report.json"]
    },
    "check-types": {},
    "playwright:install": {
      "cache": false,
      "outputs": []
    },
    "test:node": {
      "outputs": []
    },
    "test:playwright": {
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:vitest": {
      "outputs": []
    },
    "test:update": {},
    "format:write": {},
    "format:check": {}
  }
}
